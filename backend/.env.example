# ── App ─────────────────────────────────────────────────
DEBUG=false
FRONTEND_URL=https://nlc-land-docs.vercel.app

# ── Supabase (single project, land_evidence schema) ─────
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_BUCKET=land-evidence

# ── Database (Supabase pooler connection string) ─────────
DATABASE_URL=postgresql+asyncpg://postgres.XXXX:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Upstash Redis ────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@your-upstash-endpoint:6380

# ── Resend ───────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@neumlexcounsel.com

# ── Sentry (optional) ────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Admin ────────────────────────────────────────────────
ADMIN_SECRET_KEY=change-this-in-production

# ── bKash (sandbox → live when ready) ───────────────────
BKASH_APP_KEY=your_app_key
BKASH_APP_SECRET=your_app_secret
BKASH_USERNAME=your_username
BKASH_PASSWORD=your_password
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# ── Nagad ────────────────────────────────────────────────
NAGAD_MERCHANT_ID=your_merchant_id
NAGAD_MERCHANT_KEY=your_merchant_key
NAGAD_BASE_URL=https://api.mynagad.com
